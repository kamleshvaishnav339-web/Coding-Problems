#include <iostream>
using namespace std;
int  main()
{
    int number,i,even_sum=0,odd_sum=0;
    cout<<"Enter the number:";
    cin>>number;
        for(i=0;i<=number;i++){
            if(i%2==0){
                even_sum=even_sum+i;
            }
            else
                odd_sum=odd_sum+i;
        }
    even_sum%2==0?cout<<even_sum<<" Even":cout<<even_sum<<" Odd";
    odd_sum%2==0?cout<<endl<<odd_sum<<" even":cout<<endl<<odd_sum<<" Odd";
    return 0;
}
